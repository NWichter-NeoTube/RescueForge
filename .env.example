# ── OpenRouter API ──────────────────────────────────────────
OPENROUTER_API_KEY=         # Required: Get from https://openrouter.ai
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Backend ─────────────────────────────────────────────────
BACKEND_URL=http://backend:8000
MAX_UPLOAD_SIZE_MB=50

# ── Security ────────────────────────────────────────────────
# Comma-separated allowed origins for CORS (default: * allows all)
# Production example: CORS_ORIGINS=https://app.example.com,https://rescueforge.example.com
CORS_ORIGINS=*

# ── Frontend ────────────────────────────────────────────────
# For local dev: http://localhost:8000
# For production: leave empty (uses Next.js rewrites to backend service)
NEXT_PUBLIC_API_URL=http://localhost:8000
